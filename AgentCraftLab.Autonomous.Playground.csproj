<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Version>1.0.0</Version>
    <AssemblyTitle>AgentCraftLab Autonomous Playground</AssemblyTitle>
    <Description>AI 自主決策代理互動式控制台</Description>
    <LangVersion>13.0</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AgentCraftLab.Autonomous" Version="1.0.0-preview1" />
    <PackageReference Include="Spectre.Console" Version="0.54.1-alpha.0.82" />
  </ItemGroup>

</Project>
